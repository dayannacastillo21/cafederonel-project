{
  "info": {
    "name": "Cafedronel APF02",
    "description": "Coleccion para evidencias: JWT, CRUD, consultas y seguridad por roles.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "01 Publico",
      "item": [
        {
          "name": "Healthcheck",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/estado" }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cafedronel.com\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/sesiones"
          }
        },
        {
          "name": "Registro USER",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Usuario Demo\",\n  \"email\": \"demo@cafedronel.com\",\n  \"password\": \"abcd1234\"\n}"
            },
            "url": "{{baseUrl}}/api/usuarios"
          }
        }
      ]
    },
    {
      "name": "02 Seguridad",
      "item": [
        {
          "name": "Productos sin token (401)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/productos" }
        },
        {
          "name": "Productos token invalido (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer invalido" }],
            "url": "{{baseUrl}}/api/productos"
          }
        },
        {
          "name": "Admin ping",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/ping"
          }
        }
      ]
    },
    {
      "name": "03 Productos CRUD",
      "item": [
        {
          "name": "Listar activos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/productos/activos"
          }
        },
        {
          "name": "JPQL precio minimo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/productos/busqueda/precio-minimo?min=8"
          }
        },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Mocaccino\",\n  \"precio\": 14.5,\n  \"categoria\": \"bebidas\",\n  \"descripcion\": \"Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/productos"
          }
        }
      ]
    },
    {
      "name": "04 Inventario y Ventas",
      "item": [
        {
          "name": "Stock bajo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/inventario/alertas/stock-bajo"
          }
        },
        {
          "name": "Ventas por estado",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/ventas/estado/pendiente"
          }
        }
      ]
    }
  ]
}
