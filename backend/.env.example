# =============================================================================
# PLANTILLA - NO es obligatorio tener archivo .env
# =============================================================================
# En LOCAL puedes exportar estas variables en PowerShell/bash.
# En RENDER no subas .env: agrega estas variables en el panel Environment.
# No guardes passwords reales ni secretos JWT reales en Git.
# =============================================================================

PORT=8081

DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventario_backenddatabase
DB_USER=postgres
DB_PASSWORD=CAMBIAR_PASSWORD_LOCAL
DB_SSLMODE=disable

JWT_SECRET=CAMBIAR_CLAVE_JWT_MINIMO_32_CARACTERES
JWT_EXPIRATION_MS=86400000

JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
