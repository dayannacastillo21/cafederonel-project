# Copia este archivo como application-local.properties (esta en .gitignore).
# Activa el perfil: spring.profiles.active=local
# O en PowerShell antes de mvn spring-boot:run:
#   $env:SPRING_PROFILES_ACTIVE="local"

# Local PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/inventario_backenddatabase?sslmode=disable
spring.datasource.username=postgres
spring.datasource.password=CAMBIAR_PASSWORD_LOCAL

app.jwt.secret=CAMBIAR_CLAVE_JWT_LOCAL_MINIMO_32_CARACTERES
app.cors.allowed-origins=http://localhost:4200,http://127.0.0.1:4200
